{
    "format_version": "1.8.0",
    "render_controllers": {
        "controller.render.zombie_villager_v3_base": {
            "geometry": "query.is_baby? Geometry.baby : Geometry.default",
            "materials": [
                {
                    "*": "Material.default"
                }
            ],
            "textures": [
                "query.is_baby? Texture.baby_default : Texture.default"
            ]
        },
        "controller.render.zombie_villager_v3_masked_biome": {
            "arrays": {
                "textures": {
                    "Array.biomes": [
                        "Texture.plains",
                        "Texture.desert",
                        "Texture.jungle",
                        "Texture.savanna",
                        "Texture.snow",
                        "Texture.swamp",
                        "Texture.taiga"
                    ],
                    "Array.baby_biomes": [
                        "Texture.baby_plains",
                        "Texture.baby_desert",
                        "Texture.baby_jungle",
                        "Texture.baby_savanna",
                        "Texture.baby_snow",
                        "Texture.baby_swamp",
                        "Texture.baby_taiga"
                    ]
                }
            },
            "geometry": "query.is_baby? Geometry.baby_biome : Geometry.biome",
            "materials": [
                {
                    "*": "Material.default"
                }
            ],
            "textures": [
                "query.is_baby ? Array.baby_biomes[query.mark_variant] : Array.biomes[query.mark_variant]"
            ]
        },
        "controller.render.zombie_villager_v3_masked_profession": {
            "arrays": {
                "textures": {
                    "Array.professions": [
                        "Texture.unskilled",
                        "Texture.farmer",
                        "Texture.fisherman",
                        "Texture.shepherd",
                        "Texture.fletcher",
                        "Texture.librarian",
                        "Texture.cartographer",
                        "Texture.cleric",
                        "Texture.armorer",
                        "Texture.weapon_smith",
                        "Texture.tool_smith",
                        "Texture.butcher",
                        "Texture.leatherworker",
                        "Texture.stonemason",
                        "Texture.nitwit"
                    ]
                }
            },
            "geometry": "Geometry.profession",
            "part_visibility": [
                {
                    "*": "!query.is_baby"
                },
                {
                    "librarian_glass": "!query.is_baby && variable.profession_index == 5"
                },
                {
                    "cartographer_glass": "!query.is_baby && variable.profession_index == 6"
                }
            ],
            "materials": [
                {
                    "*": "Material.default"
                },
                {
                    "librarian_glass": "Material.blend"
                },
                {
                    "cartographer_glass": "Material.blend"
                }
            ],
            "textures": [
                "Array.professions[variable.profession_index]"
            ]
        }
    }
}